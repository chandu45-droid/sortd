# Database (Supabase/Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/taskflow

# WhatsApp (Meta Cloud API)
WHATSAPP_TOKEN=your_meta_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WEBHOOK_VERIFY_TOKEN=your_webhook_verify_secret
WHATSAPP_APP_SECRET=your_app_secret_for_signature_verification

# Auth (JWT signing)
JWT_SECRET=your_jwt_secret_min_32_chars

# AI (Claude Haiku for intent parsing fallback)
ANTHROPIC_API_KEY=sk-ant-your-key

# Background Jobs
CRON_SECRET=your_cron_secret
QSTASH_TOKEN=your_upstash_qstash_token
QSTASH_CURRENT_SIGNING_KEY=your_signing_key
QSTASH_NEXT_SIGNING_KEY=your_next_signing_key

# Rate Limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_token
